{
  "id": "iot-percent",
  "label": "Percentage",
  "description": "Circular percentage ring with colour thresholds.",
  "category": "Monitor",
  "dataTypes": ["Percentage"],
  "whenToUse": "Show a value as a percentage of a range — battery, capacity, progress, utilization. Set thresholds so the ring recolours by value (e.g. green, amber, red).",
  "icon": "<svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.75\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><circle cx=\"12\" cy=\"12\" r=\"9\" opacity=\"0.35\"/><path d=\"M12 3a9 9 0 0 1 7.8 13.5\"/></svg>",

  "defaultSize": { "w": 5, "h": 5 },
  "defaultProps": {
    "title": "",
    "variable": "",
    "min": 0,
    "max": 100,
    "decimals": 0,
    "unit": "%",
    "thresholds": [
      { "value": 0, "color": "#22c55e" },
      { "value": 60, "color": "#f59e0b" },
      { "value": 85, "color": "#ef4444" }
    ]
  },

  "fields": [
    { "key": "title", "label": "Title", "type": "string" },
    { "key": "variable", "label": "Variable", "type": "variable" },
    { "key": "min", "label": "Min", "type": "number" },
    { "key": "max", "label": "Max", "type": "number" },
    { "key": "decimals", "label": "Decimals", "type": "number" },
    { "key": "unit", "label": "Unit", "type": "string" },
    { "key": "thresholds", "label": "Colour thresholds", "type": "thresholds" }
  ],
  "bindings": {
    "attributes": [
      { "prop": "title", "type": "string" },
      { "prop": "variable", "type": "string" },
      { "prop": "min", "type": "number" },
      { "prop": "max", "type": "number" },
      { "prop": "decimals", "type": "number" },
      { "prop": "unit", "type": "string" }
    ],
    "properties": [
      { "prop": "thresholds", "as": "thresholds" }
    ]
  },

  "runtime": {
    "variableExtractor": { "kind": "scalar", "prop": "variable" },
    "liveUpdate": { "kind": "valueProperty" },
    "snapshot": { "kind": "valueProperty" }
  },

  "mcp": {
    "description": "Circular percentage ring with colour thresholds.",
    "propTypes": {
      "title": "string",
      "variable": "string (variable key)",
      "min": "number",
      "max": "number",
      "decimals": "number",
      "unit": "string",
      "thresholds": "Array<{ value: number, color: string }> — value is a percentage (0–100); the band with the greatest value <= current applies"
    }
  }
}
