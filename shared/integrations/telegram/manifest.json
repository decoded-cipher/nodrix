{
  "kind": "telegram",
  "label": "Telegram",
  "description": "Send a message to a Telegram chat or channel via a bot.",
  "icon": "M21.5 4.5 2.5 11.8c-.9.35-.9 1.55 0 1.9l4.6 1.55 1.75 5.5c.25.78 1.27.96 1.78.3l2.4-3.1 4.6 3.4c.7.5 1.7.1 1.85-.75L22.4 5.7c.2-1.05-.85-1.6-.9-1.2Z",
  "executable": true,
  "fields": [
    {
      "key": "bot_token",
      "label": "Bot token",
      "type": "text",
      "required": true,
      "mono": true,
      "placeholder": "123456:ABC-…",
      "hint": "From @BotFather. The bot must be a member of the target chat/channel."
    },
    {
      "key": "chat_id",
      "label": "Chat ID",
      "type": "text",
      "required": true,
      "mono": true,
      "placeholder": "-1001234567890 or @channelname",
      "hint": "Numeric chat id, or @username for a public channel."
    },
    {
      "key": "message",
      "label": "Message",
      "type": "textarea",
      "placeholder": "{{variable}} = {{value}}",
      "hint": "Supports {{variable}}, {{value}}, {{event}}, {{source}}."
    }
  ],
  "summary": { "template": "chat {{chat_id}}", "fallback": "No chat id set" }
}
