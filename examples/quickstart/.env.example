# --- Common ---
# Hostname of your worker — no scheme, no path.
NODRIX_HOST=your.workers.dev

# How often sensors POST telemetry (ms).
INTERVAL_MS=5000

# --- Sensors (HTTP) ---
# One device token per sensor. Each posts temperature + humidity.
HOME_TOKEN=
OFFICE_TOKEN=

# --- Controller (WS) ---
# Token of the device that receives commands from dashboard control widgets
# (toggle / push / slider).
CONTROLLER_TOKEN=
